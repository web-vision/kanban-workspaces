{
    "name": "web-vision/kanban-workspaces",
    "type": "typo3-cms-extension",
    "description": "Kanban Workspaces - Kanban Board Extension for TYPO3: Manage tasks and projects with an intuitive kanban interface",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "web-vision GmbH",
            "email": "hello@web-vision.de",
            "role": "Maintainer"
        },
        {
            "name": "Stefan Bürk",
            "role": "Maintainer",
            "email": "stefan@buerk.tech"
        },
        {
            "name": "WebVision",
            "email": "info@devzspace.com",
            "role": "developer"
        }
    ],
    "support": {
        "issues": "https://github.com/web-vision/kanban-workspaces/issues",
        "source": "https://github.com/web-vision/kanban-workspaces"
    },
    "require": {
        "php": "~8.2.0 || ~8.3.0 || ~8.4.0 || ~8.5.0",
        "typo3/cms-backend": "~13.4.25@dev || ~14.3.0@dev",
        "typo3/cms-core": "~13.4.25@dev || ~14.3.0@dev",
        "typo3/cms-extbase": "~13.4.25@dev || ~14.3.0@dev",
        "typo3/cms-fluid": "~13.4.25@dev || ~14.3.0@dev",
        "typo3/cms-workspaces": "~13.4.25@dev || ~14.3.0@dev"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95.1",
        "phpstan/phpstan": "^2.1.54",
        "phpstan/phpstan-phpunit": "^2.0.16",
        "phpunit/phpunit": "^11.5.55",
        "saschaegerer/phpstan-typo3": "^2.1.1 || ^3.0.1",
        "typo3/cms-install": "~13.4.25@dev || ~14.3.0@dev",
        "typo3/cms-setup": "~13.4.25@dev || ~14.3.0@dev",
        "typo3/testing-framework": "^9.5"
    },
    "autoload": {
        "psr-4": {
            "WebVision\\KanbanWorkspaces\\": "Classes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WebVision\\KanbanWorkspaces\\Tests\\": "Tests/"
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "kanban_workspaces",
            "web-dir": ".Build/Web",
            "version": "0.0.3-dev",
            "Package": {
                "providesPackages": []
            },
            "app-dir": ".Build"
        }
    },
    "config": {
        "vendor-dir": ".Build/vendor",
        "bin-dir": ".Build/bin",
        "sort-packages": true,
        "optimize-autoloader": true,
        "lock": false,
        "allow-plugins": {
            "typo3/class-alias-loader": true,
            "typo3/cms-composer-installers": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "cs:check": "${PHP_BINARY} .Build/bin/php-cs-fixer fix --config Build/php-cs-fixer/php-cs-rules.php --diff --dry-run",
        "cs:fix": "${PHP_BINARY} .Build/bin/php-cs-fixer fix --config Build/php-cs-fixer/php-cs-rules.php",
        "phpstan:core13": "${PHP_BINARY} .Build/bin/phpstan analyse -c Build/phpstan/Core13/phpstan.neon --no-progress",
        "phpstan:core14": "${PHP_BINARY} .Build/bin/phpstan analyse -c Build/phpstan/Core14/phpstan.neon --no-progress",
        "phpstan:baseline:core13": "${PHP_BINARY} .Build/bin/phpstan analyse -c Build/phpstan/Core13/phpstan.neon --generate-baseline=Build/phpstan/Core13/phpstan-baseline.neon --allow-empty-baseline",
        "phpstan:baseline:core14": "${PHP_BINARY} .Build/bin/phpstan analyse -c Build/phpstan/Core14/phpstan.neon --generate-baseline=Build/phpstan/Core14/phpstan-baseline.neon --allow-empty-baseline"
    }
}
