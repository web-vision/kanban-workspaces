{
    "name": "webvision/kanban-workspaces",
    "type": "typo3-cms-extension",
    "description": "Kanban Board Extension for TYPO3",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "WebVision",
            "email": "info@devzspace.com"
        }
    ],
    "require": {
        "php": "^8.2.0",
        "cweagans/composer-patches": "^1.7",
        "typo3/cms-backend": "~13.4.0@dev || ~14.3.0@dev",
        "typo3/cms-core": "~13.4.0@dev || ~14.3.0@dev",
        "typo3/cms-extbase": "~13.4.0@dev || ~14.3.0@dev",
        "typo3/cms-fluid": "~13.4.0@dev || ~14.3.0@dev",
        "typo3/cms-workspaces": "~13.4.0@dev || ~14.3.0@dev"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95.1",
        "typo3/cms-install": "~13.4.0@dev || ~14.3.0@dev",
        "typo3/cms-setup": "~13.4.0@dev || ~14.3.0@dev",
        "typo3/testing-framework": "^9.5"
    },
    "autoload": {
        "psr-4": {
            "WebVision\\KanbanWorkspaces\\": "Classes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WebVision\\KanbanWorkspaces\\Tests\\": "Tests/"
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "kanban_workspaces",
            "web-dir": ".Build/Web",
            "version": "1.0.0-dev",
            "Package": {
                "providesPackages": []
            }
        },
        "patches": {
            "typo3/cms-workspaces": {
                "Language fallback for GridDataService": "patches/griddata-language-fallback.patch"
            }
        }
    },
    "config": {
        "vendor-dir": ".Build/vendor",
        "bin-dir": ".Build/bin",
        "sort-packages": true,
        "optimize-autoloader": true,
        "lock": false,
        "allow-plugins": {
            "typo3/class-alias-loader": true,
            "typo3/cms-composer-installers": true,
            "cweagans/composer-patches": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "cs:check": "${PHP_BINARY} .Build/bin/php-cs-fixer fix --config Build/php-cs-fixer/php-cs-rules.php --diff --dry-run",
        "cs:fix": "${PHP_BINARY} .Build/bin/php-cs-fixer fix --config Build/php-cs-fixer/php-cs-rules.php"
    }
}
